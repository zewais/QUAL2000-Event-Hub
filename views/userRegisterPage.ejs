<%- include("partials/head", { pageTitle, shellClass: "site-shell-public" }) %>
<%- include("partials/publicNav") %>

<section class="auth-shell">
  <div class="auth-panel">
    <div class="page-header-grid">
      <span class="eyebrow">Create your account</span>
      <h1 class="page-title">Register before you start saving events.</h1>
      <p class="page-copy">
        A public account lets each user keep their own event list, calendar, and seat
        updates without affecting the admin dashboard.
      </p>
    </div>

    <%- include("partials/message", { message, errorMessage }) %>

    <form action="/register" method="POST">
      <div class="form-grid">
        <div class="form-group form-group-full">
          <label class="label" for="name">Full Name</label>
          <input
            class="input"
            id="name"
            name="name"
            type="text"
            required
            value="<%= formData.name %>"
          />
        </div>

        <div class="form-group form-group-full">
          <label class="label" for="email">Email Address</label>
          <input
            class="input"
            id="email"
            name="email"
            type="email"
            required
            value="<%= formData.email %>"
          />
        </div>

        <div class="form-group form-group-full">
          <label class="label" for="password">Password</label>
          <input class="input" id="password" name="password" type="password" required />
        </div>
      </div>

      <div class="form-actions">
        <button class="button-primary" type="submit">Create Account</button>
        <a class="button-secondary" href="/login">Already Have An Account?</a>
      </div>
    </form>
  </div>
</section>

<%- include("partials/footer") %>
