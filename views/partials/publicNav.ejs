<nav class="public-nav">
  <div class="nav-inner">
    <a class="brand-lockup" href="/">
      <span class="brand-kicker">Live Guide</span>
      <span class="brand-name">Event Hub</span>
    </a>

    <div class="nav-links">
      <a class="nav-link <%= currentPath === '/' ? 'is-active' : '' %>" href="/">
        Home
      </a>
      <a
        class="nav-link <%= currentPath.startsWith('/events') && !currentPath.startsWith('/events/registrations') ? 'is-active' : '' %>"
        href="/events"
      >
        Events
      </a>

      <% if (isUserLoggedIn) { %>
        <a
          class="nav-link <%= currentPath.startsWith('/events/registrations') && !currentPath.startsWith('/events/registrations/calendar') ? 'is-active' : '' %>"
          href="/events/registrations"
        >
          My Events
        </a>
        <a
          class="nav-link <%= currentPath.startsWith('/events/registrations/calendar') ? 'is-active' : '' %>"
          href="/events/registrations/calendar"
        >
          My Calendar
        </a>
      <% } else { %>
        <a class="nav-link <%= currentPath === '/login' ? 'is-active' : '' %>" href="/login">
          Log In
        </a>
        <a
          class="nav-link <%= currentPath === '/register' ? 'is-active' : '' %>"
          href="/register"
        >
          Register
        </a>
      <% } %>
    </div>

    <div class="nav-actions">
      <% if (isUserLoggedIn) { %>
        <span class="user-pill"><%= currentUserName %></span>
        <form action="/logout" method="POST">
          <button class="button-secondary" type="submit">Log Out</button>
        </form>
      <% } else { %>
        <a class="button-link" href="/register">Create Account</a>
      <% } %>

      <a class="button-link" href="/admin/login">Admin Dashboard</a>
    </div>
  </div>
</nav>
