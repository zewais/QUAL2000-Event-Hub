<%- include("partials/head", { pageTitle, shellClass: "site-shell-public" }) %>
<%- include("partials/publicNav") %>

<section class="page-header">
  <div class="shell-section">
    <div class="page-header-grid">
      <span class="eyebrow">My saved events</span>
      <h1 class="page-title">Track and manage the events on your calendar.</h1>
      <p class="page-copy">
        Review the events you joined, update your seat count when plans change, and
        remove an event if you no longer need it on your calendar.
      </p>
    </div>
    <%- include("partials/message", { message, errorMessage: "" }) %>
  </div>
</section>

<section class="utility-section">
  <div class="shell-section">
    <div class="inline-actions section-actions">
      <a class="button-primary" href="/events">Browse More Events</a>
      <a class="button-secondary" href="/events/registrations/calendar">Open My Calendar</a>
    </div>

    <% if (registrations.length === 0) { %>
      <div class="empty-state">
        <h2 class="empty-title">Your calendar is still empty.</h2>
        <p class="empty-copy">
          Visit the events page to open a listing and save your first event.
        </p>
        <div class="inline-actions">
          <a class="button-primary" href="/events">Browse Events</a>
        </div>
      </div>
    <% } else { %>
      <div class="registrations-table-wrap table-scroll">
        <table class="registrations-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Date</th>
              <th>Location</th>
              <th>Seats</th>
              <th>Status</th>
              <th>When</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% registrations.forEach((registration) => { %>
              <tr>
                <td>
                  <a
                    class="subtle-link"
                    href="/events/<%= registration.eventDetails._id %>"
                  >
                    <%= registration.eventDetails.title %>
                  </a>
                </td>
                <td><%= formatDate(registration.eventDetails.date) %></td>
                <td><%= registration.eventDetails.location %></td>
                <td><%= registration.ticketCount %></td>
                <td><span class="status-pill"><%= registration.status %></span></td>
                <td>
                  <span class="<%= registration.isPast ? 'status-pill status-pill-muted' : 'status-pill' %>">
                    <%= registration.isPast ? "Past Event" : "Upcoming" %>
                  </span>
                </td>
                <td>
                  <div class="table-actions">
                    <a
                      class="button-secondary button-small"
                      href="/events/registrations/<%= registration._id %>/edit"
                    >
                      Edit Seats
                    </a>
                    <form
                      action="/events/registrations/<%= registration._id %>?_method=DELETE"
                      method="POST"
                    >
                      <button class="button-danger" type="submit">
                        Remove Event
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>
