<%- include("partials/head", { pageTitle, shellClass: "site-shell-public" }) %>
<%- include("partials/publicNav") %>

<header class="hero">
  <div class="hero-inner">
    <div class="hero-badge eyebrow">Curated local experiences</div>
    <h1 class="hero-title">Event Hub</h1>
    <p class="hero-copy">
      Discover the nights worth stepping out for, from live music and food pop-ups
      to community workshops and creative festivals.
    </p>
    <div class="hero-actions inline-actions">
      <a class="button-primary" href="/events">Browse Events</a>
      <% if (isUserLoggedIn) { %>
        <a class="button-secondary button-hero-secondary" href="/events/registrations">
          View My Events
        </a>
      <% } else { %>
        <a class="button-secondary button-hero-secondary" href="/register">
          Create Your Account
        </a>
      <% } %>
    </div>
    <p class="hero-note">
      One place to explore upcoming events, save your seats, and keep your own calendar.
    </p>
  </div>
</header>

<section class="feature-band">
  <div class="shell-section">
    <%- include("partials/message", { message, errorMessage: "" }) %>

    <div class="section-header">
      <span class="eyebrow">What Event Hub offers</span>
      <h2 class="section-title">A clearer way to browse, choose, and book local events.</h2>
      <p class="section-copy">
        The public side stays focused on discovery and registration, while the admin
        dashboard keeps event updates fast and readable.
      </p>
    </div>

    <div class="stats-row">
      <div class="stat-block">
        <span class="stat-number"><%= featuredEvents.length %></span>
        <span class="stat-label">Featured events highlighted on the home page</span>
      </div>
      <div class="stat-block">
        <span class="stat-number">10</span>
        <span class="stat-label">Maximum seats a user can manage for one event</span>
      </div>
      <div class="stat-block">
        <span class="stat-number">2</span>
        <span class="stat-label">User calendar views: month grid and agenda list</span>
      </div>
    </div>
  </div>
</section>

<section class="editorial-section">
  <div class="shell-section">
    <div class="section-header">
      <span class="eyebrow">Featured now</span>
      <h2 class="section-title">Upcoming moments worth saving a spot for.</h2>
      <p class="section-copy">
        Add events from the admin dashboard and they will appear here automatically.
      </p>
    </div>

    <% if (featuredEvents.length === 0) { %>
      <div class="empty-state">
        <h3 class="empty-title">No events have been added yet.</h3>
        <p class="empty-copy">
          Start by signing in to the admin dashboard and creating your first event.
        </p>
        <div class="inline-actions">
          <a class="button-primary" href="/admin/login">Go To Admin Login</a>
        </div>
      </div>
    <% } else { %>
      <div class="event-list">
        <% featuredEvents.forEach((event) => { %>
          <article class="event-list-item">
            <a class="event-card-link" href="/events/<%= event._id %>">
              <div
                class="event-card-media"
                style="background-image: url('<%= event.image || defaultEventImage %>');"
              ></div>

              <div class="event-card-content">
                <div class="eyebrow-row">
                  <span class="meta-pill"><%= event.category %></span>
                  <span class="meta-pill"><%= formatDate(event.date) %></span>
                </div>

                <div class="event-grid">
                  <h3 class="event-title"><%= event.title %></h3>
                  <p class="event-summary"><%= event.description %></p>
                </div>

                <div class="meta-row">
                  <span><strong>Location:</strong> <%= event.location %></span>
                  <span><strong>Open slots:</strong> <%= event.availableSlots %></span>
                </div>
              </div>
            </a>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<section class="cta-section">
  <div class="shell-section">
    <div class="cta-panel">
      <span class="eyebrow">Ready to explore more?</span>
      <h2 class="cta-title">Move from the landing page into the full event directory.</h2>
      <p class="cta-copy">
        Use the events page to browse every listing, open details, and save events
        into your personal calendar when the timing fits.
      </p>
      <div class="inline-actions">
        <a class="button-primary" href="/events">See All Events</a>
        <% if (isUserLoggedIn) { %>
          <a class="button-secondary" href="/events/registrations/calendar">My Calendar</a>
        <% } else { %>
          <a class="button-secondary" href="/login">Log In To Manage Events</a>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
